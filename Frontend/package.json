{
  "name": "nuxt-app",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "test": "vitest run",
    "lint": "eslint . --ext .ts,.vue",
    "prepare": "test -d .git && husky install || echo 'Skip husky on CI'",
    "prepare:ci": "nuxt prepare",
    "format": "prettier --write .",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@clerk/nuxt": "^1.5.9",
    "@internationalized/date": "^3.8.0",
    "@nuxt/eslint": "^1.3.0",
    "@nuxt/icon": "^1.11.0",
    "@nuxt/ui": "^3.0.2",
    "eslint": "^9.24.0",
    "nuxt": "^3.16.2",
    "typescript": "^5.8.3",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@nuxt/test-utils": "^3.19.0",
    "@playwright/test": "^1.52.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vitest/coverage-v8": "^3.1.3",
    "@vue/test-utils": "^2.4.6",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-prettier": "^5.2.6",
    "flush-promises": "^1.0.2",
    "happy-dom": "^17.4.7",
    "husky": "^8.0.0",
    "jsdom": "^26.1.0",
    "lint-staged": "^15.5.1",
    "playwright": "^1.52.0",
    "playwright-core": "^1.52.0",
    "prettier": "^3.5.3",
    "vitest": "^3.1.3"
  }
}
